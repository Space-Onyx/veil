### Messages
reactor-smoke-start-message = ОПАСНО!: {$owner} ДОСТИГ ОПАСНОЙ РАБОЧЕЙ ТЕМПЕРАТУРЫ! РАБОЧАЯ ТЕМПЕРАТУРА: {$temperature}K. РЕКОМЕНДУЕТСЯ НЕМЕДЛЕННОЕ ВМЕШАТЕЛЬСТВО!
reactor-smoke-stop-message = {$owner} вернулся к номинальной рабочей температуре.
reactor-fire-start-message = ВНИМАНИЕ! ВНИМАНИЕ!: {$owner} ДОСТИГ КРИТИЧЕСКОГО РЕЖИМА! РАБОЧАЯ ТЕМПЕРАТУРА: {$temperature}K. РАСПЛАВЛЕНИЕ РЕАКТОРА НЕИЗБЕЖНО!
reactor-fire-stop-message = {$owner} вернулся к номинальной рабочей температуре. Расплавление активной зоны предотвращено.

reactor-temperature-dangerous-message = {$owner} имеет опасную температуру: {$temperature}K.
reactor-temperature-critical-message = {$owner} имеет критическую температуру: {$temperature}K.
reactor-temperature-cooling-message = {$owner} охлаждается: {$temperature}K.

reactor-melting-announcement = РАСПЛАВЛЕНИЕ ЯДЕРНОГО РЕАКТОРА НЕИЗБЕЖНО! РЕКОМЕНДУЕТСЯ НЕМЕДЛЕННАЯ ЭВАКУАЦИЯ!
reactor-melting-announcement-sender = ЯДЕРНАЯ ТРЕВОГА

reactor-meltdown-announcement = НАЧАЛОСЬ РАСПЛАВЛЕНИЕ ЯДЕРНОГО РЕАКТОРА! ТРЕБУЕТСЯ НЕМЕДЛЕННАЯ ЭВАКУАЦИЯ!
