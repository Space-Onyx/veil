# Runner Augment Names
ent-RunnerAugmentLeft = левый бегунок
    .desc = Кибернетический имплант для левой ноги. Увеличивает скорость ходьбы и бега на ~10%.
ent-RunnerAugmentRight = правый бегунок
    .desc = { ent-RunnerAugmentLeft.desc }

ent-AdvancedRunnerAugmentLeft = улучшенный левый бегунок
    .desc = Продвинутый кибернетический имплант. Увеличивает скорость ходьбы и бега на ~25%.

ent-AdvancedRunnerAugmentRight = улучшенный правый бегунок
    .desc = { ent-AdvancedRunnerAugmentRight.desc }

